# ShieldNet Environment Configuration
# Copy to .env and customize before deployment

# Zone identity
ZONE_ID=ZONE-04

# Database
DATABASE_USER=shieldnet
DATABASE_PASSWORD=change_me_now
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_DB=shieldnet_soc

# InfluxDB
INFLUXDB_PASSWORD=change_me_now

# MQTT
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_TLS_PORT=8883

# Kafka
KAFKA_BOOTSTRAP_SERVER=kafka:9092

# JWT Authentication
JWT_SECRET=change_me_now

# Federated Learning
FL_SERVER_ADDRESS=fl-server
FL_SERVER_PORT=9080
FL_INTERVAL_MINUTES=60
FL_LOCAL_EPOCHS=3
DP_EPSILON=1.0
DP_DELTA=1e-5
DP_CLIP_NORM=1.0

# SOC
SOC_WEBHOOK_URL=http://soc-api:8080/api/v1/webhook/incident
GRAFANA_PASSWORD=change_me_now

# AIRO
AIRO_CONFIRMATION_DELAY_MS=5000

# Inference thresholds
INFERENCE_THRESHOLD_LOW=0.40
INFERENCE_THRESHOLD_HIGH=0.70
